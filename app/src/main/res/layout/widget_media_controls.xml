<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/media_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/bg_media_widget"
  android:padding="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
      android:layout_width="86dp"
      android:layout_height="86dp"
      android:background="@drawable/bg_media_artwork"
      android:padding="18dp">

      <ImageView
        android:id="@+id/media_widget_artwork"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_widget_music_note" />
    </FrameLayout>

    <Space
      android:layout_width="14dp"
      android:layout_height="1dp" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:gravity="center_vertical"
      android:orientation="vertical">

      <TextView
        android:id="@+id/media_widget_source"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:background="@drawable/bg_media_source_pill"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="Spotify"
        android:textColor="@color/widget_primary"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/media_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="Nessuna riproduzione"
        android:textColor="@color/widget_on_surface"
        android:textSize="18sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/media_widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="Apri Spotify o YouTube Music"
        android:textColor="@color/widget_on_surface_variant"
        android:textSize="13sp" />

      <TextView
        android:id="@+id/media_widget_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Tocca play per abilitare"
        android:textColor="@color/widget_accent"
        android:textSize="11sp"
        android:visibility="gone" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:gravity="bottom|center_vertical"
        android:orientation="horizontal">

        <ImageButton
          android:id="@+id/media_widget_previous"
          android:layout_width="38dp"
          android:layout_height="38dp"
          android:background="@drawable/bg_media_control"
          android:contentDescription="Traccia precedente"
          android:padding="9dp"
          android:src="@drawable/ic_widget_previous" />

        <Space
          android:layout_width="8dp"
          android:layout_height="1dp" />

        <ImageButton
          android:id="@+id/media_widget_play_pause"
          android:layout_width="46dp"
          android:layout_height="46dp"
          android:background="@drawable/bg_media_control_primary"
          android:contentDescription="Play pausa"
          android:padding="10dp"
          android:src="@drawable/ic_widget_play" />

        <Space
          android:layout_width="8dp"
          android:layout_height="1dp" />

        <ImageButton
          android:id="@+id/media_widget_next"
          android:layout_width="38dp"
          android:layout_height="38dp"
          android:background="@drawable/bg_media_control"
          android:contentDescription="Traccia successiva"
          android:padding="9dp"
          android:src="@drawable/ic_widget_next" />

        <Space
          android:layout_width="0dp"
          android:layout_height="1dp"
          android:layout_weight="1" />

        <ImageButton
          android:id="@+id/media_widget_refresh"
          android:layout_width="34dp"
          android:layout_height="34dp"
          android:background="@drawable/bg_media_control"
          android:contentDescription="Aggiorna"
          android:padding="8dp"
          android:src="@drawable/ic_widget_refresh" />
      </LinearLayout>
    </LinearLayout>
  </LinearLayout>
</FrameLayout>
